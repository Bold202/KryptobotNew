[Desktop Entry]
Version=1.0
Type=Application
Name=KryptoBot
GenericName=Coinbase Crypto Assistant
Comment=Überwacht Krypto-Kurse und handelt automatisch über Coinbase
Exec=bash -c "appdir=\"${KRYPTOBOT_DIR:-$HOME/KryptobotNew}\"; source \"$appdir/.venv/bin/activate\" && python3 \"$appdir/src/main.py\""
Terminal=false
Categories=Finance;
StartupNotify=true
