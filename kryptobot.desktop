[Desktop Entry]
Version=1.0
Type=Application
Name=KryptoBot
GenericName=Coinbase Crypto Assistant
Comment=Überwacht Krypto-Kurse und handelt automatisch über Coinbase
Exec=bash -c "source $HOME/KryptobotNew/.venv/bin/activate && python3 $HOME/KryptobotNew/src/main.py"
Icon=$HOME/KryptobotNew/assets/icon.png
Terminal=false
Categories=Finance;
StartupNotify=true
